# ─────────────────────────────────────────────────────────────────────────────
# Circul-AI-r Platform — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/circulair?ssl={"rejectUnauthorized":true}
JWT_SECRET=
NODE_ENV=production

# ── Owner / Platform Identity ─────────────────────────────────────────────────
OWNER_EMAIL=owner@yourdomain.com
OWNER_NAME=Setoos
VITE_APP_TITLE=Circul-AI-r Platform

# ── OpenAI (LLM + Image Generation + Voice Transcription) ─────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ── AWS S3 (File Storage) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=circulair-storage

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...
VITE_GOOGLE_MAPS_API_KEY=AIza...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@circulair.energy

# ── Payments (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── IoT / MQTT ────────────────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtts://your-broker.example.com:8883
MQTT_USERNAME=circulair
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=CAI_

# ── Render CI/CD (GitHub Actions secrets only — do not set in production) ─────
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_ID=srv-...
